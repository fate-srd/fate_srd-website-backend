# Copy to scripts/.env.db (gitignored) and fill in values:
#   cp scripts/.env.db.example scripts/.env.db
#   chmod 600 scripts/.env.db

# SSH access to the live host (DreamHost VPS)
SSH_HOST=vps23161.dreamhostps.com
SSH_USER=replace-me
# Optional: path to SSH private key
# SSH_IDENTITY=~/.ssh/id_ed25519

# Live MySQL (reachable from the VPS; script tunnels through SSH)
DB_HOST=database.amazingrando.dev
DB_PORT=3306
DB_NAME=fate_backend
DB_USER=fatesrd_user
DB_PASSWORD=replace-me
